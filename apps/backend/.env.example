# ====================================
# PropGroup Backend Environment Variables
# ====================================

# ====================================
# DATABASE CONFIGURATION (REQUIRED)
# ====================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For Render: Get this from your Render PostgreSQL dashboard (Internal Database URL)
# Production (Render Frankfurt):
# DATABASE_URL="postgresql://propgroup_database_user:N47ZWO9oy6BsGhYdZWd7tqBivUfgCYeh@dpg-d3ro26jipnbc73epphb0-a/propgroup_database"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/propgroup"

# ====================================
# SERVER CONFIGURATION
# ====================================
# Port for the backend server (Render sets this automatically)
PORT=3001

# Node environment
NODE_ENV=production

# ====================================
# FRONTEND CONFIGURATION (REQUIRED)
# ====================================
# Frontend URL for CORS and OAuth redirects
# For production: Your Vercel deployment URL
# Can be comma-separated for multiple origins
FRONTEND_URL="https://your-frontend.vercel.app"

# Backend URL (for OAuth callbacks)
# For Render: https://your-app-name.onrender.com
BACKEND_URL="https://your-backend.onrender.com"

# API_URL — the public URL of this backend.
# Used by upload.service.ts to build proxy URLs stored in the DB.
# IMPORTANT: Use API_URL (not NEXT_PUBLIC_API_URL) — the NEXT_PUBLIC_ prefix
# is a Next.js convention and is undefined in a plain Node/Express process.
API_URL="https://your-backend.onrender.com"

# ====================================
# AUTHENTICATION (REQUIRED)
# ====================================
# JWT Secret - Use a strong random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# JWT Expiration (optional, defaults to 7d)
JWT_EXPIRES_IN="7d"

# ====================================
# GOOGLE OAUTH (OPTIONAL - For "Sign in with Google")
# ====================================
# Get these from Google Cloud Console:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable Google+ API
# 4. Go to Credentials → Create Credentials → OAuth 2.0 Client ID
# 5. Add authorized redirect URI: https://your-backend.onrender.com/api/auth/google/callback

GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="https://your-backend.onrender.com/api/auth/google/callback"

# ====================================
# ANTHROPIC CLAUDE AI (For AI-powered property search)
# ====================================
# Get your API key from https://console.anthropic.com/
# Uses Claude Haiku 4.5 (fast and cheap)

ANTHROPIC_API_KEY="your-anthropic-api-key"

# ====================================
# CLOUDFLARE R2 STORAGE (REQUIRED for uploads)
# ====================================
# Get these from the Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="propgrouplb"

# Public URL for the R2 bucket — set to your custom domain if configured.
# When set, uploaded files are served directly from Cloudflare's edge (no backend proxy hop).
# Custom domain: https://assets.propgrouplb.com
# OR the r2.dev public URL: https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_URL="https://assets.propgrouplb.com"

# ====================================
# OPTIONAL SERVICES
# ====================================
# Email service (for notifications, password resets, etc.)
# Option 1: Resend (recommended)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"

# Option 2: SendGrid
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxx"

# Email configuration
FROM_EMAIL="noreply@yourdomain.com"
ADMIN_EMAIL="admin@yourdomain.com"

# ====================================
# LOCAL DEVELOPMENT ONLY
# ====================================
# For local development, use these values:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/propgroup"
# FRONTEND_URL="http://localhost:3000"
# BACKEND_URL="http://localhost:3001"
# NODE_ENV="development"
