generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Currency {
  USD
  LBP
}

enum Country {
  LEBANON
}

// Building-level kind
enum BuildingKind {
  STANDALONE   // single unit: one apartment, one shop
  PROJECT      // developer project with many units for sale
  COMMUNITY    // residential community / compound
  MIXED_USE    // commercial + residential in same building
}

// Atomic unit kind — what kind of space is this unit
enum UnitKind {
  APARTMENT
  STUDIO
  DUPLEX
  PENTHOUSE
  VILLA
  TOWNHOUSE
  SHOP
  OFFICE
  LAND_PARCEL
  STORAGE
  PARKING
}

// Where is a unit in its life
enum UnitLifecycle {
  DRAFT          // being set up, not visible
  FOR_SALE       // listed for purchase
  RESERVED       // deposit taken, awaiting completion
  SOLD           // title transferred
  OWNER_OCCUPIED // owner lives / uses it, not rented
  FOR_RENT       // available to rent
  RENTED         // active tenancy
  VACANT         // owned but empty
  OFF_MARKET     // hidden
}

enum UnitOwnership {
  PLATFORM_SOLD // unit came through a sale on this platform
  EXTERNAL      // owner registered it; not sold through us
}

// Listing polymorphism
enum ListingSubjectType {
  BUILDING // whole building/project marketed as one
  UNIT     // single unit marketed individually
}

enum ListingIntent {
  FOR_SALE
  FOR_RENT
}

enum ListingStatus {
  DRAFT
  ACTIVE
  UNDER_OFFER
  CLOSED
  ARCHIVED
}

enum PropertyVisibility {
  PUBLIC
  ELITE_ONLY
  HIDDEN
}

// Property status (for off-plan / new builds)
enum PropertyStatus {
  OFF_PLAN
  NEW_BUILD
  RESALE
}

enum MembershipTier {
  FREE
  ELITE
  PREMIUM
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum FurnishingStatus {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

enum OwnershipType {
  FREEHOLD
  LEASEHOLD
}

enum DocumentType {
  FLOOR_PLAN
  BROCHURE
  CONTRACT
  LEGAL_DOCUMENT
  CERTIFICATE
  OTHER
}

enum InvestmentGoal {
  HIGH_ROI
  CAPITAL_GROWTH
  PASSIVE_INCOME
  LIFESTYLE
}

enum Role {
  USER
  AGENT
  PROPERTY_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  WITHDRAWN
  EXPIRED
}

enum TourStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum TourType {
  IN_PERSON
  VIRTUAL
  VIDEO_CALL
}

enum TransactionStatus {
  INITIATED
  DOCUMENTS_PENDING
  UNDER_REVIEW
  APPROVED
  PAYMENT_PENDING
  PAYMENT_COMPLETED
  COMPLETED
  CANCELLED
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  REPLIED
  CANCELLED
  CLOSED
}

enum NotificationType {
  PROPERTY_UPDATE
  PRICE_DROP
  NEW_MATCHING_PROPERTY
  RESERVATION_UPDATE
  OFFER_UPDATE
  TOUR_REMINDER
  MEMBERSHIP_EXPIRING
  DOCUMENT_UPLOADED
  MESSAGE_RECEIVED
  MAINTENANCE_UPDATE
  RENT_DUE
  SYSTEM_ANNOUNCEMENT
}

// ── Property Management enums ─────────────────────────────────────────────────

enum TenancyStatus {
  ACTIVE
  NOTICE_PERIOD
  ENDED
  EVICTED
}

enum RentPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RentPaymentStatus {
  DUE
  PARTIAL
  PAID
  OVERDUE
  WAIVED
}

// Lebanese-realistic payment methods
enum PaymentMethod {
  CASH
  BANK_TRANSFER
  OMT
  WHISH
  FRESH_USD   // actual fresh dollars (not lollar)
  LOLLAR      // USD trapped in Lebanese banks
  OTHER
}

enum TicketScope {
  UNIT            // issue inside a specific unit
  BUILDING_COMMON // elevator, water tank, lobby, etc.
}

enum TicketCategory {
  PLUMBING
  ELECTRICAL
  HVAC
  APPLIANCE
  STRUCTURAL
  CLEANING
  PEST
  KEYS_LOCKS
  INTERNET
  GENERATOR
  ELEVATOR
  WATER_TANK
  OTHER
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  EMERGENCY
}

enum TicketStatus {
  OPEN
  TRIAGED
  SCHEDULED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

// Lebanon-specific utility kinds
enum UtilityKind {
  ELECTRICITY_EDL        // state grid (hours/day)
  ELECTRICITY_GENERATOR  // private generator subscription
  WATER                  // municipal or tanker
  INTERNET
  GAS
  OTHER
}

enum AllocationMethod {
  METERED           // by kWh/m3 consumed per unit
  AREA_PROPORTIONAL // by unit sqm share
  FIXED_SHARE       // manually set % per unit
  OCCUPANT_COUNT    // by number of people in tenancy
}

enum BillStatus {
  RECORDED   // bill entered but not split yet
  ALLOCATED  // split into per-unit amounts
  INVOICED   // per-unit invoices issued
  SETTLED    // all units paid
}

enum AllocationStatus {
  PENDING
  INVOICED
  PAID
  DISPUTED
}

enum ChargeCadence {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ChargeStatus {
  DUE
  PAID
  WAIVED
  OVERDUE
}

enum ShareScope {
  BUILDING
  UNIT
  UNIT_OPTION
}

// ============================================
// CORE MODELS
// ============================================

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  password        String?
  firstName       String?
  lastName        String?
  phone           String?
  country         String?
  role            Role             @default(USER)
  investmentGoals InvestmentGoal[]

  // OAuth
  googleId String? @unique
  provider String?
  avatar   String?

  // Membership
  membershipTier      MembershipTier @default(FREE)
  membershipStartDate DateTime?
  membershipEndDate   DateTime?

  // Account status
  isActive        Boolean   @default(true)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?

  // Password reset
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  // Ban management
  bannedAt     DateTime?
  bannedBy     String?
  bannedReason String?

  // Admin invitation
  invitedBy            String?
  invitationAcceptedAt DateTime?

  // Preferences
  preferredLanguage    String? @default("en")
  preferredCurrency    String? @default("USD")
  timezone             String?
  notificationsEnabled Boolean @default(true)
  emailNotifications   Boolean @default(true)
  smsNotifications     Boolean @default(false)

  // Agent fields
  agentLicenseNumber  String?
  agentCompany        String?
  agentBio            String?
  agentCommissionRate Float?

  // Referral
  referralCode String? @unique
  referredBy   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  favoriteProperties   FavoriteProperty[]
  propertyInquiries    PropertyInquiry[]
  ownedProperties      UserOwnedProperty[]
  subscriptions        Subscription[]
  propertyReservations PropertyReservation[]
  propertyOffers       PropertyOffer[]
  propertyTours        PropertyTour[]
  notifications        Notification[]
  buyerTransactions    Transaction[]         @relation("BuyerTransactions")
  sellerTransactions   Transaction[]         @relation("SellerTransactions")
  messages             Message[]             @relation("UserMessages")
  sentMessages         Message[]             @relation("SentMessages")
  referredUsers        User[]                @relation("UserReferrals")
  referrer             User?                 @relation("UserReferrals", fields: [referredBy], references: [id])
  auditLogs            AdminAuditLog[]       @relation("AdminAuditLogs")
  bannedUsers          User[]                @relation("BannedByAdmin")
  bannedByAdmin        User?                 @relation("BannedByAdmin", fields: [bannedBy], references: [id])
  invitedUsers         User[]                @relation("InvitedByAdmin")
  invitedByAdmin       User?                 @relation("InvitedByAdmin", fields: [invitedBy], references: [id])
  managedBuildings     Building[]            @relation("BuildingAgent")

  @@index([role])
  @@index([isActive])
  @@index([email])
  @@index([membershipTier])
  @@index([referralCode])
  @@map("users")
}

model Developer {
  id          String   @id @default(cuid())
  name        String
  description String?
  website     String?
  logo        String?
  country     Country  @default(LEBANON)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  buildings Building[]

  @@map("developers")
}

model LocationGuide {
  id        String   @id @default(cuid())
  title     String
  content   String
  country   Country  @default(LEBANON)
  city      String?
  caza      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buildings Building[]

  @@map("location_guides")
}

// ── FX Rate (USD/LBP) ─────────────────────────────────────────────────────────
// Admin-maintained daily rate used for display-only conversions.
// Never auto-convert stored amounts — just annotate what rate was in effect.
model FxRate {
  id        String   @id @default(cuid())
  date      DateTime @unique
  usdToLbp  Decimal
  source    String?  // "admin", "banque_du_liban", "market"
  createdBy String?
  createdAt DateTime @default(now())

  @@index([date])
  @@map("fx_rates")
}

// ── Building ──────────────────────────────────────────────────────────────────
// The physical structure or community.  One-to-many with Unit.
// A standalone apartment or shop is a Building(STANDALONE) with one Unit.
// A developer project is a Building(PROJECT) with many Units.
model Building {
  id               String      @id @default(cuid())
  kind             BuildingKind @default(STANDALONE)
  title            String
  description      String?
  shortDescription String?

  // Location — Lebanon hierarchy
  country      Country @default(LEBANON)
  mohafazat    String? // governorate: Beirut, Mount Lebanon, North, South, Bekaa, Akkar, Baalbek-Hermel, Nabatieh
  caza         String? // district within mohafazat
  city         String?
  neighborhood String?
  address      String?
  zipCode      String?
  latitude     Float?
  longitude    Float?
  locationUrl  String? // Google Maps embed URL

  // Building specs
  builtYear     Int?
  totalFloors   Int?
  parkingSpaces Int?    @default(0)
  hasConcierge  Boolean @default(false)
  hasGenerator  Boolean @default(false)
  hasSolarPower Boolean @default(false)
  hasElevator   Boolean @default(false)
  hasPool       Boolean @default(false)
  hasGym        Boolean @default(false)
  hasGarden     Boolean @default(false)
  hasSecurity   Boolean @default(false)
  hasRooftop    Boolean @default(false)

  // Status / marketing
  status      PropertyStatus @default(RESALE)
  visibility  PropertyVisibility @default(PUBLIC)
  featured    Boolean   @default(false)
  featuredUntil DateTime?
  views       Int       @default(0)

  // Media
  images         String[]
  videoUrl       String?
  youtubeUrls    String[] @default([])
  virtualTourUrl String?

  // SEO
  slug            String?   @unique
  metaTitle       String?
  metaDescription String?

  // Investment
  highlightedFeatures String[]

  // Public sharing (legacy single token kept for compat)
  shareToken String? @unique

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  // Foreign keys
  developerId     String?
  locationGuideId String?
  agentId         String?

  // Relations
  developer     Developer?     @relation(fields: [developerId], references: [id])
  locationGuide LocationGuide? @relation(fields: [locationGuideId], references: [id])
  agent         User?          @relation("BuildingAgent", fields: [agentId], references: [id])

  units            Unit[]
  listings         Listing[]
  documents        PropertyDocument[]
  amenities        PropertyAmenity[]
  tags             PropertyTag[]
  inquiries        PropertyInquiry[]
  favorites        FavoriteProperty[]
  tours            PropertyTour[]
  offers           PropertyOffer[]
  reservations     PropertyReservation[]
  investmentData   BuildingInvestmentData?
  priceHistory     BuildingPriceHistory[]
  tickets          MaintenanceTicket[]
  serviceCharges   ServiceCharge[]
  buildingExpenses BuildingExpense[]
  utilityMeters    UtilityMeter[]
  utilityBills     UtilityBill[]

  @@index([kind])
  @@index([country])
  @@index([mohafazat])
  @@index([caza])
  @@index([status])
  @@index([visibility])
  @@index([featured])
  @@index([slug])
  @@index([agentId])
  @@index([createdAt])
  @@map("buildings")
}

model BuildingInvestmentData {
  id         String @id @default(cuid())
  buildingId String @unique

  expectedROI        Float?
  rentalYield        Float?
  capitalGrowth      Float?
  annualAppreciation Float?

  minInvestment         Float?
  maxInvestment         Float?
  downPaymentPercentage Float?
  paymentPlan           String?
  paymentPlanDetails    Json?
  installmentYears      Int?

  completionDate      DateTime?
  handoverDate        DateTime?
  expectedRentalStart DateTime?

  averageRentPerMonth Float?
  comparableProperties String[]

  mortgageAvailable Boolean @default(false)
  serviceFee        Float?
  propertyTax       Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@map("building_investment_data")
}

model BuildingPriceHistory {
  id         String   @id @default(cuid())
  buildingId String
  price      Decimal
  currency   Currency @default(USD)
  changedAt  DateTime @default(now())
  changedBy  String?
  reason     String?

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId])
  @@index([changedAt])
  @@map("building_price_history")
}

// ── Unit ──────────────────────────────────────────────────────────────────────
// The atomic leasable / saleable space.
// All pricing, bedrooms, area, images live HERE, not on the parent Building.
model Unit {
  id         String @id @default(cuid())
  buildingId String

  // Identity
  name       String?  // "2BR Type A", "Shop 3", "Penthouse"
  unitNumber String?  // "4B", "G-01", "P"
  kind       UnitKind @default(APARTMENT)

  // Specs
  bedrooms      Int?
  bathrooms     Int?
  areaSqm       Float?
  floor         Int?
  parkingSpaces Int?   @default(0)
  furnishing    FurnishingStatus?
  ownership     OwnershipType?
  views         String[] // SEA, MOUNTAIN, CITY, GARDEN, STREET
  features      String[] // BALCONY, MAID_ROOM, ROOFTOP, STORAGE, ...

  // Lifecycle & ownership
  lifecycle       UnitLifecycle @default(DRAFT)
  ownershipSource UnitOwnership @default(PLATFORM_SOLD)

  // For external units: owner contact
  ownerName        String?
  ownerPhone       String?
  ownerUserId      String?
  managedByUserId  String?
  managementNote   String?
  managementStartedAt DateTime?

  // Sale pricing (set when lifecycle = FOR_SALE/RESERVED/SOLD)
  askingPrice    Decimal?
  askingCurrency Currency?
  soldPrice      Decimal?
  soldCurrency   Currency?
  soldAt         DateTime?

  // Rental pricing (set when lifecycle = FOR_RENT/RENTED)
  rentAmount     Decimal?
  rentCurrency   Currency?
  rentPeriod     RentPeriod?

  // Generator ampere subscription (for fixed-share electricity split)
  generatorAmpere Int?

  // Media
  images  String[]
  notes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  building   Building     @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  options    UnitOption[]
  listings   Listing[]
  documents  PropertyDocument[]
  tenancies  Tenancy[]
  tickets    MaintenanceTicket[]
  meters     UtilityMeter[]
  expenses   UnitExpenseShare[]
  allocations BillAllocation[]
  priceHistory UnitPriceHistory[]

  @@index([buildingId])
  @@index([kind])
  @@index([lifecycle])
  @@index([ownershipSource])
  @@map("units")
}

model UnitPriceHistory {
  id        String   @id @default(cuid())
  unitId    String
  price     Decimal
  currency  Currency @default(USD)
  field     String   // "askingPrice" | "rentAmount"
  changedAt DateTime @default(now())
  changedBy String?
  reason    String?

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([changedAt])
  @@map("unit_price_history")
}

model UnitOption {
  id     String @id @default(cuid())
  unitId String

  name               String  // "Turnkey", "White Frame", "Black Frame", "Renovated"
  pricePerSqm        Decimal
  currency           Currency @default(USD)
  initialPayment     Decimal?
  paymentPlanDetails Json?
  description        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit      Unit               @relation(fields: [unitId], references: [id], onDelete: Cascade)
  documents PropertyDocument[]

  @@index([unitId])
  @@map("unit_options")
}

// ── Listing ───────────────────────────────────────────────────────────────────
// A marketed offer — points at either a Building (whole project) or a Unit.
// A standalone shop becomes Unit + 1 Listing.
// A project launch becomes Building + 1 Listing (then per-unit as handover nears).
model Listing {
  id String @id @default(cuid())

  subjectType ListingSubjectType
  buildingId  String?   // set when subjectType = BUILDING
  unitId      String?   // set when subjectType = UNIT

  intent     ListingIntent
  status     ListingStatus      @default(DRAFT)
  visibility PropertyVisibility @default(PUBLIC)

  // Pricing
  price      Decimal
  currency   Currency @default(USD)
  rentPeriod RentPeriod? // only for FOR_RENT

  // Marketing
  slug        String   @unique
  headline    String?
  description String?
  highlights  String[]

  publishedAt DateTime?
  closedAt    DateTime?
  closingReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building Building? @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit     Unit?     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  inquiries PropertyInquiry[]
  favorites FavoriteProperty[]

  @@index([subjectType])
  @@index([buildingId])
  @@index([unitId])
  @@index([intent])
  @@index([status])
  @@index([visibility])
  @@index([slug])
  @@index([createdAt])
  @@map("listings")
}

// ============================================
// USER INTERACTIONS
// ============================================

model FavoriteProperty {
  id         String   @id @default(cuid())
  userId     String
  buildingId String?
  listingId  String?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  building Building? @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("favorite_properties")
}

model PropertyInquiry {
  id         String        @id @default(cuid())
  userId     String?
  buildingId String?
  listingId  String?
  buildingTitle String?

  name      String
  email     String
  phone     String?
  message   String?
  status    InquiryStatus @default(NEW)
  adminNotes String?
  repliedAt  DateTime?
  repliedBy  String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @default(now()) @updatedAt

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  building Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("property_inquiries")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model UserOwnedProperty {
  id              String   @id @default(cuid())
  userId          String
  buildingId      String?
  unitId          String?
  customName      String
  purchasePrice   Decimal
  purchaseCurrency Currency @default(USD)
  purchaseDate    DateTime
  initialMortgage Decimal?
  currentRent     Decimal?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_owned_properties")
}

// ============================================
// ADMIN & AUDIT
// ============================================

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String?
  targetId   String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  admin User @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
  @@index([action])
  @@index([targetType])
  @@map("admin_audit_logs")
}

// ============================================
// SUBSCRIPTION & MEMBERSHIP
// ============================================

model Subscription {
  id             String         @id @default(cuid())
  userId         String
  membershipTier MembershipTier

  amount   Decimal
  currency Currency @default(USD)

  startDate DateTime
  endDate   DateTime
  autoRenew Boolean  @default(true)

  status PaymentStatus @default(PENDING)

  paymentGateway String?
  transactionId  String?
  paymentMethod  String?

  cancelledAt  DateTime?
  cancelReason String?
  refundedAt   DateTime?
  refundAmount Decimal?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

// ============================================
// PROPERTY RESERVATION
// ============================================

model PropertyReservation {
  id         String @id @default(cuid())
  buildingId String
  unitId     String?
  userId     String

  status          ReservationStatus @default(PENDING)
  reservationDate DateTime          @default(now())
  expiryDate      DateTime

  reservationFee Decimal?
  currency       Currency      @default(USD)
  paymentStatus  PaymentStatus @default(PENDING)
  transactionId  String?

  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?

  cancelledAt  DateTime?
  cancelReason String?

  userNotes  String?
  adminNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId])
  @@index([unitId])
  @@index([userId])
  @@index([status])
  @@index([expiryDate])
  @@map("property_reservations")
}

// ============================================
// PROPERTY DETAILS
// ============================================

model PropertyAmenity {
  id          String  @id @default(cuid())
  buildingId  String
  name        String
  category    String?
  description String?
  icon        String?

  createdAt DateTime @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId])
  @@map("property_amenities")
}

model PropertyDocument {
  id           String  @id @default(cuid())
  buildingId   String
  unitId       String?
  unitOptionId String?

  title       String
  description String?
  type        DocumentType
  fileUrl     String
  fileSize    Int?
  mimeType    String?

  isPublic Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building   Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit       Unit?       @relation(fields: [unitId], references: [id], onDelete: SetNull)
  unitOption UnitOption? @relation(fields: [unitOptionId], references: [id], onDelete: SetNull)

  @@index([buildingId])
  @@index([unitId])
  @@index([unitOptionId])
  @@index([type])
  @@map("property_documents")
}

model Tag {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  color       String?
  icon        String?
  category    String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buildingTags PropertyTag[]

  @@index([category])
  @@index([isActive])
  @@map("tags")
}

model PropertyTag {
  id         String   @id @default(cuid())
  buildingId String
  tagId      String
  createdAt  DateTime @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([buildingId, tagId])
  @@index([buildingId])
  @@index([tagId])
  @@map("property_tags")
}

// ============================================
// OFFERS & TOURS
// ============================================

model PropertyOffer {
  id         String @id @default(cuid())
  buildingId String
  unitId     String?
  userId     String

  offerAmount Decimal
  currency    Currency    @default(USD)
  status      OfferStatus @default(PENDING)

  downPayment         Decimal?
  financingType       String?
  proposedClosingDate DateTime?
  contingencies       String?

  counterAmount Decimal?
  counterTerms  String?

  expiresAt DateTime
  message    String?
  adminNotes String?

  acceptedAt      DateTime?
  rejectedAt      DateTime?
  withdrawnAt     DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId])
  @@index([unitId])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("property_offers")
}

model PropertyTour {
  id         String @id @default(cuid())
  buildingId String
  unitId     String?
  userId     String

  tourType      TourType
  status        TourStatus @default(SCHEDULED)
  scheduledDate DateTime
  duration      Int?

  attendeesCount  Int     @default(1)
  contactPhone    String?
  specialRequests String?

  meetingLink     String?
  meetingId       String?
  meetingPassword String?

  confirmedAt DateTime?
  confirmedBy String?

  completedAt        DateTime?
  noShowAt           DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  attendeeFeedback String?
  agentNotes       String?

  reminderSent   Boolean   @default(false)
  reminderSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId])
  @@index([unitId])
  @@index([userId])
  @@index([status])
  @@index([scheduledDate])
  @@map("property_tours")
}

// ============================================
// TRANSACTIONS
// ============================================

model Transaction {
  id         String  @id @default(cuid())
  buildingId String
  unitId     String?
  buyerId    String
  sellerId   String?

  status          TransactionStatus @default(INITIATED)
  transactionType String

  agreedPrice     Decimal
  currency        Currency @default(USD)
  downPayment     Decimal?
  remainingAmount Decimal?

  paymentSchedule Json?

  initiatedAt         DateTime  @default(now())
  contractSignedAt    DateTime?
  depositPaidAt       DateTime?
  finalPaymentAt      DateTime?
  completedAt         DateTime?
  expectedClosingDate DateTime?
  actualClosingDate   DateTime?

  contractUrl         String?
  legalRepresentative String?
  notaryDetails       String?

  documentsComplete  Boolean @default(false)
  inspectionComplete Boolean @default(false)
  fundingApproved    Boolean @default(false)
  titleTransferred   Boolean @default(false)

  notes         String?
  internalNotes String?

  cancelledAt        DateTime?
  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer  User  @relation("BuyerTransactions", fields: [buyerId], references: [id], onDelete: Cascade)
  seller User? @relation("SellerTransactions", fields: [sellerId], references: [id], onDelete: SetNull)

  @@index([buildingId])
  @@index([unitId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([expectedClosingDate])
  @@map("transactions")
}

// ============================================
// PROPERTY MANAGEMENT
// ============================================

// ── Vendor ────────────────────────────────────────────────────────────────────
model Vendor {
  id       String   @id @default(cuid())
  name     String
  trades   String[] // ["PLUMBING","ELECTRICAL"]
  phone    String?
  whatsapp String?
  email    String?
  notes    String?
  rating   Float?
  isActive Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets MaintenanceTicket[]

  @@map("vendors")
}

// ── Tenancy ───────────────────────────────────────────────────────────────────
model Tenancy {
  id     String @id @default(cuid())
  unitId String

  tenantName     String
  tenantUserId   String?
  tenantPhone    String?
  tenantEmail    String?
  tenantWhatsapp String?

  startDate DateTime
  endDate   DateTime?

  rentAmount   Decimal
  rentCurrency Currency   @default(USD)
  rentPeriod   RentPeriod @default(MONTHLY)

  depositAmount   Decimal?
  depositCurrency Currency?

  status         TenancyStatus @default(ACTIVE)
  contractFileKey String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit     Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  payments RentPayment[]

  @@index([unitId])
  @@index([status])
  @@index([startDate])
  @@map("tenancies")
}

model RentPayment {
  id         String @id @default(cuid())
  tenancyId  String

  dueDate    DateTime
  paidDate   DateTime?
  amount     Decimal
  currency   Currency          @default(USD)
  method     PaymentMethod?
  status     RentPaymentStatus @default(DUE)

  receiptFileKey String?
  notes          String?
  recordedBy     String // userId of staff

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenancy Tenancy @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  @@index([tenancyId])
  @@index([status])
  @@index([dueDate])
  @@map("rent_payments")
}

// ── Maintenance ───────────────────────────────────────────────────────────────
model MaintenanceTicket {
  id         String      @id @default(cuid())
  buildingId String
  unitId     String?     // null = building-common issue
  scope      TicketScope @default(UNIT)

  category    TicketCategory  @default(OTHER)
  priority    TicketPriority  @default(NORMAL)
  status      TicketStatus    @default(OPEN)

  title       String
  description String

  // Reporter — may or may not be a platform user
  reportedBy    String?
  reporterName  String?
  reporterPhone String?
  reporterWhatsapp String?

  // Assignment
  assignedToUserId String?
  vendorId         String?

  // Cost tracking
  costEstimate Decimal?
  costActual   Decimal?
  costCurrency Currency?

  scheduledFor DateTime?
  resolvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building Building            @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit     Unit?               @relation(fields: [unitId], references: [id], onDelete: SetNull)
  vendor   Vendor?             @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  photos   TicketPhoto[]
  updates  TicketUpdate[]

  @@index([buildingId])
  @@index([unitId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([createdAt])
  @@map("maintenance_tickets")
}

model TicketPhoto {
  id        String @id @default(cuid())
  ticketId  String
  fileKey   String
  caption   String?
  uploadedBy String?
  createdAt DateTime @default(now())

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_photos")
}

model TicketUpdate {
  id           String       @id @default(cuid())
  ticketId     String
  authorUserId String
  body         String
  statusFrom   TicketStatus?
  statusTo     TicketStatus?
  createdAt    DateTime     @default(now())

  ticket MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_updates")
}

// ── Utilities ─────────────────────────────────────────────────────────────────

model UtilityMeter {
  id          String   @id @default(cuid())
  buildingId  String
  unitId      String?  // null = building-level / common meter
  kind        UtilityKind
  identifier  String?  // meter serial or subscription ID
  unitOfMeasure String @default("kWh") // kWh, amp, m3, GB
  isActive    Boolean  @default(true)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building Building         @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit     Unit?            @relation(fields: [unitId], references: [id], onDelete: SetNull)
  readings UtilityReading[]

  @@index([buildingId])
  @@index([unitId])
  @@index([kind])
  @@map("utility_meters")
}

model UtilityReading {
  id        String   @id @default(cuid())
  meterId   String
  readingAt DateTime
  value     Decimal              // cumulative meter value
  consumed  Decimal?             // diff vs previous (computed on insert)
  enteredBy String              // userId of staff
  photoKey  String?             // R2 key of meter photo

  createdAt DateTime @default(now())

  meter UtilityMeter @relation(fields: [meterId], references: [id], onDelete: Cascade)

  @@index([meterId])
  @@index([readingAt])
  @@map("utility_readings")
}

model UtilityBill {
  id          String   @id @default(cuid())
  buildingId  String
  kind        UtilityKind
  periodStart DateTime
  periodEnd   DateTime
  totalAmount Decimal
  currency    Currency @default(USD)
  totalConsumed Decimal? // total kWh/m3 on invoice (for METERED splits)
  invoiceFileKey String?
  status      BillStatus @default(RECORDED)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building    Building         @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  allocations BillAllocation[]

  @@index([buildingId])
  @@index([kind])
  @@index([periodStart])
  @@index([status])
  @@map("utility_bills")
}

model BillAllocation {
  id      String @id @default(cuid())
  billId  String
  unitId  String

  method  AllocationMethod
  basis   Decimal?   // kWh consumed, sqm ratio, headcount
  share   Decimal    // fraction of total (0–1)
  amount  Decimal    // currency amount this unit owes
  currency Currency  @default(USD)

  status   AllocationStatus @default(PENDING)
  paidAt   DateTime?
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bill UtilityBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  unit Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([unitId])
  @@index([status])
  @@map("bill_allocations")
}

// ── Service Charges (recurring HOA / maintenance fees) ────────────────────────
model ServiceCharge {
  id          String   @id @default(cuid())
  buildingId  String
  name        String
  description String?
  amount      Decimal
  currency    Currency @default(USD)
  cadence     ChargeCadence @default(MONTHLY)
  splitMethod AllocationMethod @default(AREA_PROPORTIONAL)
  isActive    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  building  Building           @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unitShares UnitExpenseShare[]

  @@index([buildingId])
  @@index([isActive])
  @@map("service_charges")
}

model UnitExpenseShare {
  id              String  @id @default(cuid())
  unitId          String
  serviceChargeId String?
  billAllocationId String?
  description     String?

  amount   Decimal
  currency Currency @default(USD)
  dueDate  DateTime
  paidAt   DateTime?
  status   ChargeStatus @default(DUE)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit          Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  serviceCharge ServiceCharge? @relation(fields: [serviceChargeId], references: [id], onDelete: SetNull)

  @@index([unitId])
  @@index([status])
  @@index([dueDate])
  @@map("unit_expense_shares")
}

model BuildingExpense {
  id          String   @id @default(cuid())
  buildingId  String
  description String
  amount      Decimal
  currency    Currency @default(USD)
  category    String   // "REPAIR", "CLEANING", "INSURANCE", "MAINTENANCE", ...
  vendorId    String?
  splitMethod AllocationMethod?
  spentAt     DateTime
  receiptFileKey String?
  notes       String?

  createdAt DateTime @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@index([buildingId])
  @@index([spentAt])
  @@map("building_expenses")
}

// ============================================
// NOTIFICATIONS & MESSAGING
// ============================================

model Notification {
  id     String @id @default(cuid())
  userId String

  type    NotificationType
  title   String
  message String

  link        String?
  actionLabel String?
  actionUrl   String?

  relatedEntityType String?
  relatedEntityId   String?

  isRead Boolean   @default(false)
  readAt DateTime?

  priority  String    @default("normal")
  expiresAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([type])
  @@map("notifications")
}

model Message {
  id String @id @default(cuid())

  senderId    String
  recipientId String

  subject String?
  body    String

  buildingId String?

  attachments String[]

  isRead Boolean   @default(false)
  readAt DateTime?

  parentMessageId String?
  threadId        String?

  createdAt DateTime @default(now())

  sender    User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User @relation("UserMessages", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([recipientId])
  @@index([threadId])
  @@index([buildingId])
  @@index([parentMessageId])
  @@index([createdAt])
  @@map("messages")
}

// ============================================
// SYSTEM SETTINGS & CMS
// ============================================

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  description String?
  category    String?
  isPublic    Boolean @default(false)

  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([category])
  @@map("system_settings")
}

model SiteContent {
  id      String @id @default(cuid())
  key     String @unique
  section String

  title    String?
  content  String?
  metadata Json?

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([section])
  @@index([isActive])
  @@map("site_content")
}

model SiteMedia {
  id      String @id @default(cuid())
  key     String @unique
  section String

  url     String
  alt     String?
  caption String?

  width    Int?
  height   Int?
  fileSize Int?
  mimeType String?

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([section])
  @@index([isActive])
  @@map("site_media")
}

// ============================================
// SHARE TOKENS
// ============================================

model ShareToken {
  id           String     @id @default(cuid())
  token        String     @unique
  scope        ShareScope
  buildingId   String
  unitId       String?
  unitOptionId String?
  createdById  String?

  createdAt DateTime  @default(now())
  expiresAt DateTime?
  revokedAt DateTime?

  @@index([buildingId])
  @@index([unitId])
  @@index([unitOptionId])
  @@map("share_tokens")
}

// ============================================
// ANALYTICS — first-party behavioural events
// ============================================
// Lightweight append-only event log powering the admin analytics dashboard.
// IDs (listingId/buildingId/unitId) are intentionally loose references (no FK)
// so events survive entity deletion and inserts stay cheap. No PII beyond an
// anonymous client session id + user agent.
model AnalyticsEvent {
  id         String   @id @default(cuid())
  type       String   // page_view | listing_view | listing_click | inquiry_click | phone_click | whatsapp_click | search | favorite
  path       String?
  listingId  String?
  buildingId String?
  unitId     String?
  sessionId  String?  // anonymous visitor session (client-generated uuid)
  userId     String?  // set when the visitor is authenticated
  referrer   String?
  userAgent  String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([listingId])
  @@index([sessionId])
  @@map("analytics_events")
}
