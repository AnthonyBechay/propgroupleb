# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/propgroupleb?schema=public"
JWT_SECRET="change-me-use-a-long-random-string"
JWT_EXPIRES_IN="7d"
FRONTEND_URL="https://yourdomain.com"
ALLOWED_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=10000
NODE_ENV="production"

# ── Cloudflare R2 (file uploads) ─────────────────────────────────────────────
# All four are required for uploads to work. Find them in Cloudflare Dashboard
# → R2 → your bucket → Settings / API tokens.
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="propgroupleb"
# Public bucket URL (r2.dev subdomain shown on bucket Settings → Public Access).
# The backend builds proxied /api/files/<key> URLs using this.
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxx.r2.dev"

# ── File proxy / frontend URL ─────────────────────────────────────────────────
# The public URL of the backend API. Used by the upload service to construct
# proxied file URLs returned in API responses.
NEXT_PUBLIC_API_URL="https://api.yourdomain.com"

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Either set GOOGLE_CALLBACK_URL explicitly, or set BACKEND_URL and the app
# will append /api/auth/google/callback automatically.
GOOGLE_CALLBACK_URL="https://api.yourdomain.com/api/auth/google/callback"
BACKEND_URL="https://api.yourdomain.com"

# ── Transactional email (optional) ───────────────────────────────────────────
# Leave blank to disable all outbound emails.
RESEND_API_KEY=""
FROM_EMAIL="PropGroup Lebanon <noreply@yourdomain.com>"
ADMIN_EMAIL="admin@yourdomain.com"

# ── AI search (optional) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""
