# ====================================
# PropGroup Frontend Environment Variables
# ====================================

# ====================================
# API CONFIGURATION (REQUIRED)
# ====================================
# Backend API URL
# For production on Vercel: Your Render backend URL
# For local development: http://localhost:3001/api
NEXT_PUBLIC_API_URL="https://your-backend.onrender.com/api"

# ====================================
# CLOUDFLARE R2 — DIRECT IMAGE SERVING (RECOMMENDED)
# ====================================
# Set to your R2 custom domain (or pub-*.r2.dev URL).
# When set, normalizeFileUrl() rewrites all /api/files/* proxy URLs to this
# Cloudflare edge domain — images load from the CDN instead of bouncing
# through the backend container (~80% of image traffic offloaded).
# Must match images.remotePatterns in next.config.ts (already included).
NEXT_PUBLIC_R2_PUBLIC_URL="https://assets.propgrouplb.com"

# ====================================
# OPTIONAL SERVICES
# ====================================
# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Google Maps API (optional - for property location maps)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaSy..."

# ====================================
# DO NOT SET THESE - Automatically handled by Vercel
# ====================================
# These are automatically set by Vercel:
# - NODE_ENV (set by Vercel)
# - VERCEL_URL (set by Vercel)
# - VERCEL_ENV (set by Vercel)

# ====================================
# LOCAL DEVELOPMENT ONLY
# ====================================
# For local development, use:
# NEXT_PUBLIC_API_URL="http://localhost:3001/api"
